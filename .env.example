# Backend base URL used by the SPA at runtime.
# In development, requests to /api, /health and /version are proxied to
# VITE_DEV_PROXY_TARGET (see vite.config.ts), so you can leave
# VITE_API_BASE_URL empty to use same-origin relative paths.
VITE_API_BASE_URL=

# Dev-only: where the Vite dev server proxies /api, /health and /version.
VITE_DEV_PROXY_TARGET=http://localhost:8000
