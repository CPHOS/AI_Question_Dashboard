# ============================================================================
# AI 命题系统 —— 一键部署环境变量  (api + dashboard)
# ============================================================================
# 用法:  cp compose.prod.env.example .env   →   编辑 .env   →   docker compose up -d
#
# 本文件涵盖 api（FastAPI 后端）和 dashboard（React 前端）的全部可配项。
# api 服务通过 env_file 读取所有变量；dashboard 服务仅使用标记了 ▸▸ 的项。
# ============================================================================


# ============================================================================
#  ▸▸ 镜像与端口
# ============================================================================

AIQ_API_IMAGE=ghcr.io/cphos/ai_question
AIQ_API_TAG=latest
AIQ_WEB_IMAGE=ghcr.io/cphos/ai_question_dashboard
AIQ_WEB_TAG=latest

# Dashboard 对外端口（默认 80，与宿主机冲突时改为其他端口，如 8080）
AIQ_WEB_PORT=80

# 是否在 api 镜像内安装 TeX Live (xelatex)，体积很大；一般不装
INSTALL_TEXLIVE=false


# ============================================================================
#  ▸▸ Dashboard（前端）
# ============================================================================

# nginx 反代目标（Compose 内部用服务名 api，一般无需修改）
BACKEND_URL=http://api:8000

# 注入前端 JS 的 API 基址：留空 = 同源相对路径（经 nginx 反代，推荐）
VITE_API_BASE_URL=

# 子目录部署路径，如 /ai-question ；留空 = 根路径 /
BASE_PATH=

# ----------------------------------------------------------------------------
# 若前置 nginx 作子目录代理（例: https://example.com/ai-question/ ），
# 推荐在外部 nginx 用 proxy_pass 末尾 / 裁剪前缀，此时 BASE_PATH 留空即可:
#
#   location /ai-question/ { proxy_pass http://127.0.0.1:8080/; }
#
# 若不便裁剪前缀，设置 BASE_PATH=/ai-question 让容器自行处理。
# ----------------------------------------------------------------------------


# ============================================================================
#  ▸▸ API 后端 —— 基础设施
# ============================================================================

# SQLite 数据文件路径（Compose 内固定 /app/data，一般不修改）
DB_PATH=data/api.db

# 同时执行的生成任务上限（每个任务耗时数分钟）
MAX_CONCURRENT_JOBS=1

# 跨域来源，逗号分隔。同源反代部署留空即可。
CORS_ALLOW_ORIGINS=

# LaTeX 编译后端: local（本机 subprocess）或 remote（独立编译服务）
# Docker 部署推荐 remote
LATEX_COMPILER_BACKEND=remote

# LaTeX 引擎
LATEX_ENGINE=xelatex

# 产物输出目录
# OUTPUT_DIR=output


# ============================================================================
#  ▸▸ 安全
# ============================================================================

# 引导管理员 token（首次启动无 admin 用户时自动创建）。
# 用随机长字符串生成，通过安全渠道分发给管理员。留空则不创建。
# 生成示例: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_BOOTSTRAP_TOKEN=


# ============================================================================
# LLM 服务商与模型（仅数据库首次初始化时播种）
# ----------------------------------------------------------------------------
# 以下变量在数据库首次创建时写入，后续修改请通过管理员面板（/admin/llm）。
# ============================================================================

# 服务商: openrouter | openai_compatible
LLM_PROVIDER=openrouter

# ---- OpenRouter ----
OPENROUTER_API_KEY=

# ---- 通用 OpenAI 兼容 (DeepSeek / 本地部署等) ----
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com/v1

# ---- 大模型（命题 / 审核 / 仲裁） ----
BIG_MODEL_NAME=google/gemini-2.5-pro-preview
BIG_MODEL_TEMPERATURE=0.7
BIG_MODEL_MAX_TOKENS=32768
ARBITER_MAX_TOKENS=4096
REVIEW_TEMPERATURE=0.0

# ---- 小模型（格式化排版） ----
SMALL_MODEL_NAME=openai/gpt-4o-mini
SMALL_MODEL_TEMPERATURE=0.0
SMALL_MODEL_MAX_TOKENS=8192

# ---- 服务商通用参数 ----
MODEL_TIMEOUT=600
LLM_MAX_RETRIES=3
LLM_STREAMING=false


# ============================================================================
# 流程参数（仅数据库首次初始化时播种）
# ============================================================================

MAX_RETRY_COUNT=3
SOURCE_MATERIAL_MAX_CHARS=60000
AUTO_COMPILE_FIGURES=true
AUTO_COMPILE_LATEX=false
LATEX_COMPILE_TIMEOUT=180

# ---- 远程 LaTeX 编译服务（LATEX_COMPILER_BACKEND=remote 时使用） ----
# LATEX_SERVICE_BASE_URL=
# LATEX_SERVICE_API_KEY=
LATEX_SERVICE_POLL_INTERVAL=2.0
LATEX_SERVICE_MAX_WAIT=1200.0

# ---- SSE 实时进度 ----
SSE_POLL_INTERVAL=1.0
SSE_MAX_DURATION=1800.0


# ============================================================================
# FormatChecker 格式检查（可选）
# ============================================================================
# FORMAT_CHECK_ENABLED=1
# FORMAT_CHECK_DIR=external/FormatChecker
# FORMAT_CHECK_MIN_SEVERITY=warning
# FORMAT_CHECK_TIMEOUT=30
